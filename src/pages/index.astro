---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionNav from '../components/SectionNav.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import Projects from '../components/Projects.astro';
import TechStack from '../components/TechStack.astro';
import About from '../components/About.astro';
---

<BaseLayout>
  <Hero />

  <section class="portfolio-sections" aria-label="Contenido del portfolio">
    <SectionNav />

    <div class="portfolio-sections__content">
      <section id="experiencia" class="content-placeholder">
        <ExperienceCard />
      </section>

      <section id="proyectos" class="content-placeholder">
        <Projects />
      </section>

      <section id="stack" class="content-placeholder">
        <TechStack />
      </section>

      <section id="sobre-mi" class="content-placeholder">
        <About />
      </section>

    </div>
  </section>
</BaseLayout>
